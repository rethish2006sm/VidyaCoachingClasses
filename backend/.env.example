# Primary database (courses, results, leaderboard, offers, inquiries)
MONGO_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/main

# Gallery database (image assets)
MONGO_GALLERY_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/gallery

# User database (students, faculty, subjects)
MONGO_USER_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/users

# Allowed origin for the frontend
CLIENT_URL=http://localhost:5173

# Backend port (defaults to 5000)
PORT=5000
